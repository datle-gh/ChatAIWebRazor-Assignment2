@section Scripts {
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script>
        (() => {
            const progressBlocks = Array.from(document.querySelectorAll('[data-verify-progress]'));
            const reviewButtons = Array.from(document.querySelectorAll('.open-review-modal'));
            const verifyForms = [];
            if (progressBlocks.length === 0 && reviewButtons.length === 0) {
                return;
            }

            const reviewModal = document.getElementById('documentReviewModal');
            const approveForm = document.getElementById('documentReviewApproveForm');
            const rejectForm = document.getElementById('documentReviewRejectForm');
            const fileNameLabel = document.getElementById('documentReviewFileName');
            const rejectReason = document.getElementById('rejectReason');
            const reviewError = document.querySelector('[data-review-error]');
            const approveButton = document.querySelector('[data-review-approve-button]');
            const rejectButton = document.querySelector('[data-review-reject-button]');

            let connection;
            let startPromise;
            const joinedUploads = new Set();

            async function ensureConnection() {
                if (!connection) {
                    connection = new signalR.HubConnectionBuilder()
                        .withUrl('/hubs/upload-progress')
                        .withAutomaticReconnect()
                        .build();
                    connection.on('UploadProgressUpdated', updateProgress);
                }

                if (!startPromise) {
                    startPromise = connection.start();
                }

                await startPromise;
            }

            async function joinUpload(uploadId) {
                if (!uploadId || joinedUploads.has(uploadId)) {
                    return;
                }

                await ensureConnection();
                await connection.invoke('JoinUpload', uploadId);
                joinedUploads.add(uploadId);
            }

            function getProgressBlock(documentId) {
                return document.querySelector(`[data-verify-progress="${documentId}"]`);
            }

            function setProgress(documentId, percent, message, isFailed, isCompleted) {
                const block = getProgressBlock(documentId);
                if (!block) {
                    return;
                }

                block.classList.remove('d-none');
                const bar = block.querySelector('[data-progress-bar]');
                const label = block.querySelector('[data-progress-message]');
                if (bar) {
                    bar.style.width = `${Math.max(0, Math.min(100, percent || 0))}%`;
                }
                if (label) {
                    label.textContent = message || 'Đang index tài liệu...';
                    label.classList.toggle('text-danger', Boolean(isFailed));
                    label.classList.toggle('text-success', Boolean(isCompleted));
                    label.classList.toggle('text-muted', !isFailed && !isCompleted);
                }
            }

            function updateProgress(progress) {
                const uploadId = progress.uploadId ?? progress.UploadId ?? '';
                const documentId = Number.parseInt(uploadId.replace('verify-', ''), 10);
                if (!Number.isFinite(documentId)) {
                    return;
                }

                setProgress(
                    documentId,
                    progress.percent ?? progress.Percent ?? 0,
                    progress.message ?? progress.Message ?? '',
                    progress.isFailed ?? progress.IsFailed,
                    progress.isCompleted ?? progress.IsCompleted);
            }

            progressBlocks.forEach(block => {
                joinUpload(block.dataset.uploadId).catch(() => {});
            });

            function showReviewError(message) {
                if (!reviewError) {
                    return;
                }

                reviewError.textContent = message || 'Không thể xử lý tài liệu.';
                reviewError.classList.remove('d-none');
            }

            function clearReviewError() {
                if (reviewError) {
                    reviewError.textContent = '';
                    reviewError.classList.add('d-none');
                }
            }

            function setReviewButtonsDisabled(isDisabled) {
                if (approveButton) {
                    approveButton.disabled = isDisabled;
                }
                if (rejectButton) {
                    rejectButton.disabled = isDisabled;
                }
            }

            reviewButtons.forEach(button => {
                button.addEventListener('click', () => {
                    clearReviewError();
                    setReviewButtonsDisabled(false);

                    if (approveButton) {
                        approveButton.textContent = 'Duyệt và index';
                    }
                    if (rejectButton) {
                        rejectButton.textContent = 'Từ chối';
                    }
                    if (fileNameLabel) {
                        fileNameLabel.textContent = button.dataset.documentName || '--';
                    }
                    if (rejectReason) {
                        rejectReason.value = '';
                    }
                    if (approveForm) {
                        approveForm.action = button.dataset.verifyUrl || '';
                        approveForm.dataset.documentId = button.dataset.documentId || '';
                        approveForm.dataset.uploadId = button.dataset.uploadId || '';
                    }
                    if (rejectForm) {
                        rejectForm.action = button.dataset.rejectUrl || '';
                        rejectForm.dataset.documentId = button.dataset.documentId || '';
                    }
                });
            });

            if (approveForm) {
                approveForm.addEventListener('submit', async event => {
                    event.preventDefault();

                    const documentId = approveForm.dataset.documentId;
                    const uploadId = approveForm.dataset.uploadId;
                    await joinUpload(uploadId);
                    setProgress(Number.parseInt(documentId, 10), 5, 'Đang gửi yêu cầu duyệt tài liệu...', false, false);
                    setReviewButtonsDisabled(true);
                    if (approveButton) {
                        approveButton.innerHTML = '<span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>Đang duyệt';
                    }

                    try {
                        const response = await fetch(approveForm.action, {
                            method: 'POST',
                            body: new FormData(approveForm),
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });
                        const payload = await response.json();
                        if (!response.ok || !payload.succeeded) {
                            throw new Error(payload.message || 'Không thể duyệt tài liệu.');
                        }

                        if (reviewModal && window.bootstrap) {
                            bootstrap.Modal.getOrCreateInstance(reviewModal).hide();
                        }
                        setProgress(Number.parseInt(documentId, 10), 100, payload.message || 'Tài liệu đã được index.', false, true);
                        window.setTimeout(() => window.location.reload(), 900);
                    } catch (error) {
                        showReviewError(error.message || 'Duyệt tài liệu thất bại.');
                        setProgress(Number.parseInt(documentId, 10), 100, error.message || 'Duyệt tài liệu thất bại.', true, false);
                        setReviewButtonsDisabled(false);
                        if (approveButton) {
                            approveButton.textContent = 'Duyệt và index';
                        }
                    }
                });
            }

            if (rejectForm) {
                rejectForm.addEventListener('submit', async event => {
                    event.preventDefault();

                    setReviewButtonsDisabled(true);
                    if (rejectButton) {
                        rejectButton.innerHTML = '<span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>Đang từ chối';
                    }

                    try {
                        const response = await fetch(rejectForm.action, {
                            method: 'POST',
                            body: new FormData(rejectForm),
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });
                        const payload = await response.json();
                        if (!response.ok || !payload.succeeded) {
                            throw new Error(payload.message || 'Không thể từ chối tài liệu.');
                        }

                        window.location.reload();
                    } catch (error) {
                        showReviewError(error.message || 'Từ chối tài liệu thất bại.');
                        setReviewButtonsDisabled(false);
                        if (rejectButton) {
                            rejectButton.textContent = 'Từ chối';
                        }
                    }
                });
            }

            verifyForms.forEach(form => {
                form.addEventListener('submit', async event => {
                    event.preventDefault();

                    const documentId = form.dataset.documentId;
                    const uploadId = form.dataset.uploadId;
                    const button = form.querySelector('button[type="submit"]');

                    await joinUpload(uploadId);
                    setProgress(Number.parseInt(documentId, 10), 5, 'Đang gửi yêu cầu duyệt tài liệu...', false, false);

                    if (button) {
                        button.disabled = true;
                        button.innerHTML = '<span class="spinner-border spinner-border-sm" aria-hidden="true"></span><span>Đang duyệt</span>';
                    }

                    try {
                        const response = await fetch(form.action, {
                            method: 'POST',
                            body: new FormData(form),
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });
                        const payload = await response.json();
                        if (!response.ok || !payload.succeeded) {
                            throw new Error(payload.message || 'Không thể duyệt tài liệu.');
                        }

                        setProgress(Number.parseInt(documentId, 10), 100, payload.message || 'Tài liệu đã được index.', false, true);
                        window.setTimeout(() => window.location.reload(), 900);
                    } catch (error) {
                        setProgress(Number.parseInt(documentId, 10), 100, error.message || 'Duyệt tài liệu thất bại.', true, false);
                        if (button) {
                            button.disabled = false;
                            button.innerHTML = '<span class="material-symbols-outlined" style="font-size:1rem">verified</span><span>Duyệt</span>';
                        }
                    }
                });
            });
        })();
    </script>
}

@functions {
    private static string GetFileIcon(string fileType) => fileType.ToUpperInvariant() switch
    {
        "PDF"  => "picture_as_pdf",
        "DOCX" => "description",
        "PPTX" => "slideshow",
        _      => "insert_drive_file"
    };

    private static string GetFileIconClass(string fileType) => fileType.ToUpperInvariant() switch
    {
        "PDF"  => "icon-pdf",
        "DOCX" => "icon-docx",
        "PPTX" => "icon-pptx",
        _      => "icon-default"
    };

    private static string GetStatusClass(DocumentStatus status) => status switch
    {
        DocumentStatus.Indexed    => "status-indexed",
        DocumentStatus.Processing => "status-processing",
        DocumentStatus.Uploaded   => "status-uploaded",
        DocumentStatus.Failed     => "status-failed",
        DocumentStatus.Rejected   => "status-failed",
        _                         => "status-uploaded"
    };

    private static string GetStatusText(DocumentStatus status) => status switch
    {
        DocumentStatus.Indexed    => "Đã Index",
        DocumentStatus.Processing => "Đang Index",
        DocumentStatus.Uploaded   => "Chờ duyệt",
        DocumentStatus.Failed     => "Lỗi",
        DocumentStatus.Rejected   => "Đã từ chối",
        _                         => status.ToString()
    };

    private static string FormatFileSize(long? bytes)
    {
        if (!bytes.HasValue) return "--";
        if (bytes.Value < 1024) return $"{bytes.Value} B";
        var kb = bytes.Value / 1024d;
        if (kb < 1024) return $"{kb:0.#} KB";
        return $"{kb / 1024d:0.#} MB";
    }

    private static string SanitizeErrorMessage(string message)
    {
        return IsTechnicalError(message)
            ? "Có lỗi khi xử lý tài liệu. Vui lòng duyệt lại hoặc tải lại tài liệu."
            : message;
    }

    private static bool IsTechnicalError(string? message)
    {
        if (string.IsNullOrWhiteSpace(message))
        {
            return false;
        }

        return message.Contains("entity type", StringComparison.OrdinalIgnoreCase)
            || message.Contains("same key value", StringComparison.OrdinalIgnoreCase)
            || message.Contains("DbContext", StringComparison.OrdinalIgnoreCase)
            || message.Contains("System.", StringComparison.OrdinalIgnoreCase)
            || message.Contains("Microsoft.", StringComparison.OrdinalIgnoreCase);
    }
}
