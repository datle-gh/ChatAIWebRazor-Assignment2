@using BusinessObject.Enums
@model DocumentIndexViewModel

@{
    bool isStudent = User.IsInRole("Student");
    bool canUpload = User.IsInRole("Admin") || User.IsInRole("Teacher");
    bool inSubjectView = Model.SubjectId.HasValue;
    var selectedSubject = inSubjectView ? Model.Subjects.FirstOrDefault(s => s.Id == Model.SubjectId) : null;

    ViewData["Title"] = inSubjectView
        ? (selectedSubject != null ? $"Tài liệu - {selectedSubject.SubjectName}" : "Chi tiết tài liệu môn học")
        : "Kho tài liệu";
}

@* ══════════════════════════════════════════════════════════════════════
   VIEW A — Grid môn học (khi chưa chọn môn)
   ══════════════════════════════════════════════════════════════════════ *@
@if (!inSubjectView)
{
    <div class="page-heading">
        <h1 class="page-title">Kho tài liệu</h1>
        <p class="page-subtitle">Truy cập tài liệu học tập đã được AI phân tích và lập chỉ mục theo từng môn học.</p>
    </div>

    @if (Model.Subjects.Count == 0)
    {
        <div class="surface-card padded text-center py-5">
            <span class="material-symbols-outlined icon-fill" style="font-size:3.5rem;color:var(--outline-variant)">folder_off</span>
            <h2 class="h4 fw-bold mt-3">Chưa có môn học nào</h2>
            <p class="text-muted">Bạn chưa được đăng ký vào môn học nào có tài liệu.</p>
        </div>
    }
    else
    {
        @* Subject card grid *@
        <div class="doc-subject-grid">
            @{
                // Icon colors cycling
                string[] iconBgs = { "rgba(226,223,255,0.6)", "rgba(255,219,204,0.5)", "rgba(208,225,251,0.6)", "rgba(254,240,138,0.4)", "rgba(255,218,214,0.4)" };
                string[] iconColors = { "var(--primary-container)", "var(--tertiary-container)", "var(--secondary)", "#a16207", "var(--danger)" };
                string[] icons = { "menu_book", "science", "computer", "history_edu", "calculate" };
                int idx = 0;
            }
            @foreach (var subject in Model.Subjects)
            {
                var docCount = Model.Documents.Count(d => d.SubjectId == subject.Id && d.Status == DocumentStatus.Indexed);
                var iconBg   = iconBgs[idx % iconBgs.Length];
                var iconColor= iconColors[idx % iconColors.Length];
                var icon     = icons[idx % icons.Length];
                idx++;

                <a href="@Url.Action("Index", "Document", new { subjectId = subject.Id })"
                   class="doc-subject-card" aria-label="Xem tài liệu môn @subject.SubjectName">
                    <div class="doc-subject-card-top">
                        <div class="doc-subject-icon" style="background:@iconBg;color:@iconColor">
                            <span class="material-symbols-outlined icon-fill" aria-hidden="true">@icon</span>
                        </div>
                        <span class="doc-subject-code">@subject.SubjectCode</span>
                    </div>
                    <h3 class="doc-subject-name">@subject.SubjectName</h3>
                    <p class="doc-subject-count">
                        <span class="material-symbols-outlined" style="font-size:1rem;vertical-align:middle">library_books</span>
                        @docCount tài liệu đã index
                    </p>
                    <div class="doc-subject-btn">
                        <span>Xem tài liệu</span>
                        <span class="material-symbols-outlined" style="font-size:1.1rem">arrow_forward</span>
                    </div>
                </a>
            }
        </div>
    }
}
else
{
    @* ══════════════════════════════════════════════════════════════════════
       VIEW B — Bảng tài liệu chi tiết theo môn học
       ══════════════════════════════════════════════════════════════════════ *@

    @* Back breadcrumb *@
    <div class="mb-3">
        <a class="doc-back-link" asp-action="Index">
            <span class="material-symbols-outlined" style="font-size:1.1rem;transition:transform 150ms ease" aria-hidden="true">arrow_back</span>
            Quay lại danh sách môn học
        </a>
    </div>

    @* Page header *@
    <div class="page-heading d-flex flex-column flex-xl-row justify-content-between gap-3">
        <div>
            <h1 class="page-title">@(selectedSubject?.SubjectName ?? "Tài liệu môn học")</h1>
            <p class="page-subtitle">Quản lý và tra cứu tài liệu học tập, bài giảng và tài nguyên liên quan đến môn học.</p>
        </div>
        @if (canUpload)
        {
            <a class="btn btn-primary px-4 align-self-start" asp-action="Upload" asp-route-subjectId="@Model.SubjectId">
                <span class="material-symbols-outlined" style="font-size:1rem;vertical-align:middle;margin-right:4px" aria-hidden="true">upload_file</span>
                Tải tài liệu lên
            </a>
        }
    </div>

    @* Toolbar / search within subject *@
    <div class="surface-card overflow-hidden mb-0">
        <div class="doc-detail-toolbar">
            <form asp-action="Index" method="get" class="doc-detail-search-form">
                <input type="hidden" name="subjectId" value="@Model.SubjectId" />
                <div class="input-with-icon" style="flex:1;max-width:420px">
                    <span class="material-symbols-outlined input-symbol" style="font-size:1.1rem">search</span>
                    <input id="searchTerm" name="searchTerm" value="@Model.SearchTerm"
                           class="form-control" style="min-height:40px;padding-left:42px"
                           placeholder="Tìm kiếm tên tài liệu trong môn này..." />
                </div>
                <button type="submit" class="btn btn-outline-primary" style="min-height:40px;padding:0 16px">Tìm</button>
            </form>
            <div class="doc-detail-count">
                Hiển thị <strong>@Model.Documents.Count</strong> tài liệu
            </div>
        </div>

        @if (Model.Documents.Count == 0)
        {
            <div class="p-5 text-center">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                     style="width:64px;height:64px;background:var(--surface-container)">
                    <span class="material-symbols-outlined" style="font-size:2rem;color:var(--on-surface-variant)">folder_off</span>
                </div>
                <h2 class="h5 fw-bold">Chưa có tài liệu nào</h2>
                <p class="text-muted mb-0" style="font-size:0.875rem">
                    @if (!isStudent)
                    {
                        <span>Hãy tải tài liệu đầu tiên cho môn học này.</span>
                    }
                    else
                    {
                        <span>Môn học này chưa có tài liệu được tải lên. Vui lòng quay lại sau.</span>
                    }
                </p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table doc-detail-table align-middle" id="documentTable">
                    <thead>
                        <tr>
                            <th style="width:38%">Tên tài liệu</th>
                            <th style="width:16%">Người tải lên</th>
                            <th style="width:10%">Loại file</th>
                            <th style="width:14%">Ngày tải lên</th>
                            <th style="width:22%" class="text-end">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doc in Model.Documents)
                        {
                            <tr class="doc-detail-row">
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="doc-detail-file-icon @GetFileIconClass(doc.FileType)" aria-hidden="true">
                                            <span class="material-symbols-outlined icon-fill">@GetFileIcon(doc.FileType)</span>
                                        </div>
                                        <div class="min-w-0 flex-grow-1">
                                            <span class="doc-detail-filename">@doc.OriginalFileName</span>
                                            <div class="doc-verify-progress @(doc.Status == DocumentStatus.Processing ? "" : "d-none") mt-2"
                                                 data-verify-progress="@doc.Id"
                                                 data-upload-id="verify-@doc.Id">
                                                <div class="progress-thin mb-1">
                                                    <span data-progress-bar style="width:@(doc.Status == DocumentStatus.Processing ? "10%" : "0%")"></span>
                                                </div>
                                                <div class="text-muted" data-progress-message style="font-size:0.78rem">
                                                    @(doc.Status == DocumentStatus.Processing ? "Đang index tài liệu..." : "Đang chờ xử lý...")
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-muted" style="font-size:0.875rem">
                                    @(doc.UploadedByName ?? "Không rõ")
                                </td>
                                <td class="text-muted" style="font-size:0.875rem">@doc.FileType</td>
                                <td class="text-muted" style="font-size:0.875rem">
                                    @doc.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy")
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-1">
                                        @if (!isStudent)
                                        {
                                            @if (doc.Status is DocumentStatus.Uploaded or DocumentStatus.Failed)
                                            {
                                                <button class="doc-row-btn doc-row-btn-primary open-review-modal"
                                                        type="button"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#documentReviewModal"
                                                        data-document-id="@doc.Id"
                                                        data-document-name="@doc.OriginalFileName"
                                                        data-upload-id="verify-@doc.Id"
                                                        data-verify-url="@Url.Action("Verify", "Document", new { id = doc.Id, subjectId = Model.SubjectId })"
                                                        data-reject-url="@Url.Action("Reject", "Document", new { id = doc.Id, subjectId = Model.SubjectId })"
                                                        title="Duyệt hoặc từ chối tài liệu">
                                                        <span class="material-symbols-outlined" style="font-size:1rem">verified</span>
                                                        <span>Duyệt</span>
                                                    </button>
                                            }
                                            <a class="doc-row-btn doc-row-btn-primary"
                                               href="@Url.Action("Chunks", "Document", new { id = doc.Id })"
                                               title="Xem phân đoạn tài liệu">
                                                <span class="material-symbols-outlined" style="font-size:1rem">visibility</span>
                                                <span>Xem</span>
                                            </a>
                                        }
                                        <a class="doc-row-btn doc-row-btn-download"
                                           href="@Url.Action("Download", "Document", new { id = doc.Id })"
                                           title="Tải xuống tài liệu"
                                           download>
                                            <span class="material-symbols-outlined" style="font-size:1rem">download</span>
                                            <span>Tải</span>
                                        </a>
                                        <button class="doc-row-btn doc-row-btn-secondary" type="button" title="Đặt câu hỏi về tài liệu"
                                                onclick="window.location='@Url.Action("Index", "Chat", new { subjectId = doc.SubjectId })'">
                                            <span class="material-symbols-outlined" style="font-size:1rem">psychology</span>
                                            <span>Hỏi AI</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@if (!isStudent)
{
    <div class="modal fade" id="documentReviewModal" tabindex="-1" aria-labelledby="documentReviewModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" style="max-width:620px">
            <div class="modal-content review-modal-card">

                
                <div class="review-modal-header">
                    <div class="review-modal-header-icon">
                        <span class="material-symbols-outlined icon-fill" aria-hidden="true">verified_user</span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="review-modal-eyebrow mb-0">Kiểm duyệt tài liệu</p>
                        <h2 class="review-modal-title" id="documentReviewModalLabel">Xem xét &amp; Phê duyệt</h2>
                    </div>
                    <button type="button" class="review-modal-close" data-bs-dismiss="modal" aria-label="Đóng">
                        <span class="material-symbols-outlined" style="font-size:1.1rem">close</span>
                    </button>
                </div>

                <div class="modal-body p-0">

                    
                    <div class="review-modal-file-wrap">
                        <div class="review-modal-file-chip">
                            <span class="review-modal-file-icon">
                                <span class="material-symbols-outlined icon-fill" aria-hidden="true">description</span>
                            </span>
                            <span class="review-modal-file-name" id="documentReviewFileName">--</span>
                        </div>
                    </div>

                    
                    <div class="alert alert-danger d-none mx-4 mb-0" data-review-error role="alert"></div>

                    
                    <div class="review-modal-section">
                        <div class="review-modal-section-label">
                            <span class="material-symbols-outlined" aria-hidden="true">block</span>
                            Lý do từ chối <span class="text-muted fw-normal" style="font-size:0.78rem">(không bắt buộc)</span>
                        </div>
                        <form id="documentReviewRejectForm" method="post">
                            @Html.AntiForgeryToken()
                            <textarea class="form-control review-modal-textarea"
                                      id="rejectReason"
                                      name="reason"
                                      rows="3"
                                      maxlength="500"
                                      placeholder="Ví dụ: Tài liệu chưa đúng môn học hoặc nội dung chưa đủ rõ."></textarea>
                        </form>
                        <form id="documentReviewApproveForm" method="post">
                            @Html.AntiForgeryToken()
                        </form>
                    </div>

                </div>

                
                <div class="review-modal-footer">
                    <button type="button" class="review-btn review-btn-ghost" data-bs-dismiss="modal">Hủy bỏ</button>
                    <div class="d-flex gap-2">
                        <button type="submit" form="documentReviewRejectForm"
                                class="review-btn review-btn-reject" data-review-reject-button>
                            <span class="material-symbols-outlined" style="font-size:1rem">cancel</span>
                            Từ chối
                        </button>
                        <button type="submit" form="documentReviewApproveForm"
                                class="review-btn review-btn-approve" data-review-approve-button>
                            <span class="material-symbols-outlined" style="font-size:1rem">verified</span>
                            Duyệt &amp; Index
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>
}

<style>
    /* ── Subject Grid ── */
    .doc-subject-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 24px;
        align-items: stretch;
    }

    @@media (min-width: 768px) {
        .doc-subject-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (min-width: 1280px) {
        .doc-subject-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .doc-subject-card {
        display: flex;
        flex-direction: column;
        padding: 24px;
        min-height: 220px;
        background: var(--surface-lowest);
        border: 1px solid rgba(199,196,216,0.4);
        border-radius: 16px;
        box-shadow: var(--shadow-indigo);
        text-decoration: none;
        color: var(--on-surface);
        transition: border-color 220ms ease, box-shadow 220ms ease, transform 150ms ease;
        cursor: pointer;
    }

    .doc-subject-card:hover {
        border-color: rgba(79,70,229,0.3);
        box-shadow: 0 8px 24px rgba(79,70,229,0.1);
        transform: translateY(-2px);
        color: var(--on-surface);
    }

    .doc-subject-card-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 14px;
    }

    .doc-subject-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        border-radius: var(--radius-md);
        font-size: 1.4rem;
    }

    .doc-subject-code {
        font-size: 0.72rem;
        font-weight: 700;
        font-family: 'Inter', sans-serif;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--on-surface-variant);
        background: var(--surface-container);
        padding: 3px 8px;
        border-radius: 4px;
    }

    .doc-subject-name {
        font-family: 'Be Vietnam Pro', sans-serif;
        font-size: 1.1rem;
        font-weight: 600;
        line-height: 1.35;
        margin: 0 0 6px;
        transition: color 160ms ease;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .doc-subject-card:hover .doc-subject-name {
        color: var(--primary-container);
    }

    .doc-subject-count {
        font-size: 0.82rem;
        color: var(--on-surface-variant);
        margin: 0 0 16px;
        font-family: 'Inter', sans-serif;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .doc-subject-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        margin-top: auto;
        padding: 9px 0;
        background: var(--surface-container);
        border-radius: var(--radius-sm);
        font-size: 0.82rem;
        font-weight: 600;
        font-family: 'Inter', sans-serif;
        color: var(--primary-container);
        transition: background-color 160ms ease, color 160ms ease;
    }

    .doc-subject-card:hover .doc-subject-btn {
        background: var(--primary-container);
        color: #fff;
    }

    /* ── Detail view ── */
    .doc-back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--secondary);
        font-size: 0.875rem;
        font-weight: 600;
        text-decoration: none;
        padding: 4px 8px;
        border-radius: var(--radius-sm);
        margin-left: -8px;
        transition: color 150ms ease, background 150ms ease;
    }

    .doc-back-link:hover {
        color: var(--primary-container);
        background: rgba(79,70,229,0.05);
    }

    .doc-back-link:hover .material-symbols-outlined {
        transform: translateX(-3px);
        transition: transform 150ms ease;
    }

    .doc-detail-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 14px 20px;
        border-bottom: 1px solid rgba(199,196,216,0.4);
        background: rgba(247,249,251,0.5);
        flex-wrap: wrap;
    }

    .doc-detail-search-form {
        display: flex;
        align-items: center;
        gap: 10px;
        flex: 1;
        min-width: 0;
    }

    .doc-detail-count {
        font-size: 0.82rem;
        color: var(--on-surface-variant);
        font-family: 'Inter', sans-serif;
        white-space: nowrap;
    }

    .doc-detail-table {
        margin: 0;
    }

    .doc-detail-table thead tr {
        background: var(--surface-container);
    }

    .doc-detail-table th {
        color: var(--on-surface-variant);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        padding: 12px 20px;
        border-bottom: 1px solid rgba(199,196,216,0.5);
    }

    .doc-detail-table td {
        padding: 16px 20px;
        vertical-align: middle;
    }

    .doc-detail-row:hover {
        background: rgba(247,249,251,0.5);
    }

    .doc-detail-expand-row td {
        padding: 0 !important;
        border-top: 0 !important;
    }

    .doc-detail-file-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: var(--radius-sm);
        flex-shrink: 0;
    }

    .doc-detail-file-icon.icon-pdf {
        background: rgba(255,218,214,0.55);
        color: var(--danger);
    }

    .doc-detail-file-icon.icon-pptx {
        background: #ffdbcc;
        color: #a44100;
    }

    .doc-detail-file-icon.icon-docx {
        background: rgba(226,223,255,0.7);
        color: var(--primary-container);
    }

    .doc-detail-file-icon.icon-default {
        background: var(--surface-container);
        color: var(--secondary);
    }

    .doc-detail-filename {
        font-weight: 500;
        font-size: 0.9rem;
        color: var(--on-surface);
        transition: color 150ms ease;
    }

    .doc-detail-row:hover .doc-detail-filename {
        color: var(--primary-container);
    }

    .doc-row-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 12px;
        border: 0;
        border-radius: var(--radius-sm);
        font-size: 0.78rem;
        font-weight: 600;
        font-family: 'Inter', sans-serif;
        cursor: pointer;
        text-decoration: none;
        transition: background-color 150ms ease, color 150ms ease;
    }

    .doc-row-btn:hover {
        text-decoration: none;
    }

    .doc-row-btn-primary {
        color: var(--primary-container);
        background: rgba(79,70,229,0.07);
    }

    .doc-row-btn-primary:hover {
        background: rgba(79,70,229,0.14);
    }

    .doc-row-btn-secondary {
        color: var(--secondary);
        background: var(--surface-container);
    }

    .doc-row-btn-secondary:hover {
        color: var(--on-surface);
        background: var(--surface-high);
    }


    /* ── Download button ── */
    .doc-row-btn-download {
        color: #0d6efd;
        background: rgba(13,110,253,0.07);
        text-decoration: none;
    }

    .doc-row-btn-download:hover {
        background: rgba(13,110,253,0.14);
        color: #0a58ca;
    }

    /* ── Premium Review Modal ── */
    .review-modal-card {
        border: 0;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 24px 60px rgba(15,23,42,0.2),
                    0 4px 12px rgba(79,70,229,0.1);
    }

    .review-modal-header {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 24px 28px 20px;
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        color: #fff;
    }

    .review-modal-header-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        background: rgba(255,255,255,0.2);
        border: 1.5px solid rgba(255,255,255,0.3);
        border-radius: 14px;
        flex-shrink: 0;
    }

    .review-modal-header-icon .material-symbols-outlined {
        font-size: 1.6rem;
        color: #fff;
    }

    .review-modal-title {
        font-family: 'Be Vietnam Pro', sans-serif;
        font-size: 1.2rem;
        font-weight: 700;
        margin: 0;
        color: #fff;
        line-height: 1.3;
    }

    .review-modal-eyebrow {
        color: rgba(255,255,255,0.75);
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .review-modal-close {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        margin-left: auto;
        flex-shrink: 0;
        background: rgba(255,255,255,0.15);
        border: 0;
        border-radius: 8px;
        color: #fff;
